# Database (same Neon Postgres as the web app)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Shared secret with the web app — must equal AGENT_API_SECRET in the root .env.local
# so requests from agent-api pass isAgentRequest() in the Next.js routes.
AGENT_API_SECRET=

# Gemini API (company key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PLANNER_MODEL=gemini-2.5-pro

# VieroClick web app — agent-api calls back here to fetch project data and post reports
VIEROC_API_URL=http://localhost:3000
VIEROC_API_KEY=

# Telegram — optional secret used to verify webhook authenticity
TELEGRAM_WEBHOOK_SECRET=
PUBLIC_BASE_URL=
# Enable FastAPI /docs and verbose logging
AGENT_API_DEBUG=true
