# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Auth GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Python Agent API — the single agent service (Celery worker/beat + FastAPI).
# Web dispatches interactive jobs to POST {AGENT_API_URL}/api/agents/{role}
# (planning, assignment, observer, ...) with the X-Api-Secret header.
AGENT_API_URL=http://localhost:8000
AGENT_API_SECRET=

# Company Gemini API (used by apps/agent-api)
GEMINI_API_KEY=
# Optional: company gateway/proxy base URL for Gemini (leave empty for native API)
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-flash
# Planner uses the strongest model; everything else uses GEMINI_MODEL
GEMINI_PLANNER_MODEL=gemini-2.5-pro

# Redis
REDIS_URL=redis://localhost:6379

# S3-compatible storage
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=vieroc-files
STORAGE_REGION=ap-southeast-1

# Telegram
# Bot token is stored per-workspace in DB table `telegram_bots`, not here.
# TELEGRAM_WEBHOOK_SECRET is optional — when set, FastAPI verifies the
# `X-Telegram-Bot-Api-Secret-Token` header on each webhook request.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Optional chat id for best-effort broadcasts (e.g. morning-briefing overview).
TELEGRAM_BROADCAST_CHAT_ID=
# Public HTTPS URL Telegram can POST updates to (ngrok URL in dev, real domain in prod).
# Required for auto-registering bot webhooks on agent-api startup.
PUBLIC_BASE_URL=

# VieroClick internal API key (used by agent-api to call back to the web app)
# Must match AGENT_API_SECRET so isAgentRequest() passes
VIEROC_API_URL=http://localhost:3000
VIEROC_API_KEY=

# OpenAI (legacy; agent-api now uses Gemini)
OPENAI_API_KEY=

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
