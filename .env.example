# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Python Agent API
AGENT_API_URL=http://localhost:8000
AGENT_API_SECRET=

# Local Agent Service (replaces Band.ai — agents communicate over plain HTTP)
# The web app dispatches jobs to this service: POST {AGENT_SERVICE_URL}/agents/{role}
AGENT_SERVICE_URL=http://localhost:8001
# Shared secret the web app sends; the agent service falls back to VIEROC_API_TOKEN.
AGENT_SERVICE_SECRET=

# Company Gemini API (used by band-agents and apps/agent-api)
GEMINI_API_KEY=
# Optional: company gateway/proxy base URL for Gemini (leave empty for native API)
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-flash
# Planner uses the strongest model; everything else uses GEMINI_MODEL
GEMINI_PLANNER_MODEL=gemini-2.5-pro

# Redis
REDIS_URL=redis://localhost:6379

# S3-compatible storage
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=vieroc-files
STORAGE_REGION=ap-southeast-1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
