# =============================================================================
# Environment Variables (EXAMPLE)
# Copy this to .env and fill in your real values
# =============================================================================

# --- LLM Providers ---
# Fill in at least one provider key
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=

# --- Model Selection Config ---
# Specify which provider to use: 'openai' or 'anthropic'
# Leave empty to auto-detect based on which key is filled above
LLM_PROVIDER=

# Default model per provider (used when no agent-specific override is set)
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Per-Agent Model Overrides (optional) ---
# Override the model for individual agents. Falls back to provider default if left empty.
PLANNING_MODEL=gpt-4o
ASSIGNMENT_MODEL=gpt-4o
OBSERVER_MODEL=gpt-4o
DAILY_REPORT_MODEL=gpt-4o
MORNING_BRIEFING_MODEL=gpt-4o
PROJECT_QA_MODEL=gpt-4o


# --- VieroClick App Integration ---
# The base URL of your running VieroClick Next.js app
VIEROC_API_URL=http://localhost:3000
# Static service key — must match AGENT_API_SECRET in apps/web/.env (never expires)
VIEROC_API_TOKEN=your-agent-api-secret
# UUID of the project agents should operate on (copy from the URL bar in VieroClick UI)
VIEROC_DEFAULT_PROJECT_ID=your-project-uuid


# --- Telegram (Optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Default Band Room ID ---
# The chat room where all agents are active (from app.band.ai)
BAND_ROOM_ID=your-band-room-id


# --- Custom Agent Handles ---
# Format: @<your-band-username>/<agent-name>
# Find your username in app.band.ai -> Profile
PLANNING_HANDLE=@username/planning
ASSIGNMENT_HANDLE=@username/assignment
OBSERVER_HANDLE=@username/observer
DAILY_REPORT_HANDLE=@username/daily-report
MORNING_BRIEFING_HANDLE=@username/morning-briefing
PROJECT_QA_HANDLE=@username/project-qa
