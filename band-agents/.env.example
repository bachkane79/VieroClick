# =============================================================================
# Environment Variables (EXAMPLE)
# Copy this to .env and fill in your real values
# =============================================================================

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=

# --- VieroClick App Integration ---
# The base URL of your running VieroClick Next.js app
VIEROC_API_URL=http://localhost:3000
# A valid user session token or API key for VieroClick
VIEROC_API_TOKEN=your-vieroc-session-token

# --- Telegram (Optional, uses existing VieroClick Telegram module) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Default Band Room ID (set after creating the room in app.band.ai) ---
BAND_ROOM_ID=your-band-room-id

# --- Custom Agent Handles (required if Band workspace prefixes handles, e.g., @username/agent) ---
DEVELOPER_HANDLE=@username/developer
QA_HANDLE=@username/qa-agent
REVIEWER_HANDLE=@username/reviewer
NOTIFIER_HANDLE=@username/notifier

