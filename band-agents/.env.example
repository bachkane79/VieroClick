# =============================================================================
# Environment Variables (EXAMPLE)
# Copy this to .env and fill in your real values
# =============================================================================

# --- LLM Provider: Company Gemini API (native Google Gemini) ---
GEMINI_API_KEY=your-company-gemini-api-key
# Optional: only set if the company routes Gemini through a gateway/proxy.
GEMINI_BASE_URL=

# Default model for every agent.
GEMINI_MODEL=gemini-2.5-flash

# --- Per-Agent Model Overrides (optional) ---
# Planner uses the strongest model; the rest fall back to GEMINI_MODEL.
PLANNING_MODEL=gemini-2.5-pro
ASSIGNMENT_MODEL=
OBSERVER_MODEL=
DAILY_REPORT_MODEL=
MORNING_BRIEFING_MODEL=
PROJECT_QA_MODEL=


# --- Local Agent Service (replaces Band.ai) ---
# The web app POSTs to http://<host>:<port>/agents/{role}
AGENT_SERVICE_HOST=0.0.0.0
AGENT_SERVICE_PORT=8001
# Shared secret the web app sends (X-Api-Secret / Bearer). Defaults to VIEROC_API_TOKEN.
AGENT_SERVICE_SECRET=


# --- VieroClick App Integration ---
# The base URL of your running VieroClick Next.js app
VIEROC_API_URL=http://localhost:3000
# Static service key — must match AGENT_API_SECRET in apps/web/.env (never expires)
VIEROC_API_TOKEN=your-agent-api-secret
# UUID of the project agents should operate on when no projectId is passed in the request
VIEROC_DEFAULT_PROJECT_ID=your-project-uuid


# --- Telegram (Optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
