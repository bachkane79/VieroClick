# =============================================================================
# Band AI Agent Configuration (EXAMPLE)
# Copy this to agent_config.yaml and fill in your real values
# IMPORTANT: Add agent_config.yaml to .gitignore — contains live API keys!
# =============================================================================

# How to get these values:
# 1. Go to app.band.ai -> Agents -> New Agent -> External Agent
# 2. Give it a name & description matching each role below
# 3. Copy the API Key shown ONCE after creation
# 4. Get the Agent UUID from the agent settings page

planning:
  agent_id: "uuid-for-planning-agent"
  api_key: "band-api-key-for-planning"

assignment:
  agent_id: "uuid-for-assignment-agent"
  api_key: "band-api-key-for-assignment"

observer:
  agent_id: "uuid-for-observer-agent"
  api_key: "band-api-key-for-observer"

daily_report:
  agent_id: "uuid-for-daily-report-agent"
  api_key: "band-api-key-for-daily-report"

morning_briefing:
  agent_id: "uuid-for-morning-briefing-agent"
  api_key: "band-api-key-for-morning-briefing"

project_qa:
  agent_id: "uuid-for-project-qa-agent"
  api_key: "band-api-key-for-project-qa"
